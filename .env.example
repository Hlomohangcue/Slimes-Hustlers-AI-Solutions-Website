# Slimes.Hustlers AI Solutions - Environment Template
# Copy this file to a local .env file for tooling that supports dotenv.
# Do not commit real secrets to source control.
#
# For Cloudflare Workers runtime secrets, prefer:
#   npx wrangler secret put ADMIN_PASSWORD
#   npx wrangler secret put ADMIN_TOKEN
#
# For GitHub Actions deployment, add secrets in repository settings.

# --------------------------------------------------
# Application Configuration Variables
# --------------------------------------------------
NODE_ENV=development
APP_NAME=Slimes.Hustlers AI Solutions Website
PUBLIC_BASE_URL=http://127.0.0.1:8787
ADMIN_PORTAL_PATH=/admin.html
CONTACT_API_PATH=/api/contacts

# --------------------------------------------------
# Authentication Placeholders (sensitive)
# --------------------------------------------------
ADMIN_PASSWORD=replace_with_strong_password
ADMIN_TOKEN=replace_with_long_random_token
SESSION_COOKIE_NAME=admin_token
SESSION_TTL_SECONDS=86400

# --------------------------------------------------
# Cloudflare Configuration Placeholders
# --------------------------------------------------
CLOUDFLARE_ACCOUNT_ID=replace_with_cloudflare_account_id
CLOUDFLARE_API_TOKEN=replace_with_cloudflare_api_token
CLOUDFLARE_WORKER_NAME=slimes-hustlers-ai-solutions-website
CLOUDFLARE_ENV=production
CLOUDFLARE_KV_BINDING=CONTACTS_KV
CLOUDFLARE_KV_NAMESPACE_ID=replace_with_contacts_kv_namespace_id
CLOUDFLARE_KV_PREVIEW_ID=replace_with_contacts_kv_preview_id

# --------------------------------------------------
# Future AI Integration Placeholders
# --------------------------------------------------
AI_PROVIDER=replace_with_ai_provider
AI_API_KEY=replace_with_ai_api_key
AI_MODEL=replace_with_model_name
AI_LEAD_SCORING_ENABLED=false
AI_LEAD_SCORING_THRESHOLD=0.75
AI_AUTOMATION_WEBHOOK_URL=https://example.com/lead-automation-webhook
AI_WEBHOOK_SIGNING_SECRET=replace_with_webhook_signing_secret
